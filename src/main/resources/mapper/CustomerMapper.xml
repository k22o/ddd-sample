<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dddsample.infrastructure.db.mapper.CustomerMapper">

    <select id="findById" resultType="com.example.dddsample.infrastructure.db.record.CustomerRecord">
        SELECT id, name, email, postal_code, prefecture, city, street
        FROM customers
        WHERE id = #{id}
    </select>

</mapper>
